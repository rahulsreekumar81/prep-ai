{
  "name": "@prepai/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed/index.ts",
    "db:seed:dsa": "dotenv -e ../../.env -- tsx src/seed/dsa.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "@neondatabase/serverless": "^0.10.0",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
