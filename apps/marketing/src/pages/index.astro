---
import Base from '../layouts/base.astro'
---

<Base title="PrepAI — Crack Your Dream Interview with AI">
  <main>
    <!-- Hero -->
    <section class="flex min-h-[80vh] flex-col items-center justify-center px-6 text-center">
      <h1 class="max-w-4xl text-6xl font-bold tracking-tight text-gray-900">
        Your AI Interview Coach
      </h1>
      <p class="mt-6 max-w-2xl text-xl text-gray-600">
        Upload your resume. Paste the job description. Get custom mock interviews with real-time AI
        feedback, voice recording, and company-specific preparation.
      </p>
      <div class="mt-8 flex gap-4">
        <a
          href="https://app.prepai.in/auth/signup"
          class="rounded-lg bg-blue-600 px-8 py-4 text-lg font-medium text-white hover:bg-blue-700"
        >
          Start Free Mock Interview
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-500">No credit card required. 3 free interviews/month.</p>
    </section>

    <!-- Features -->
    <section class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-6 py-20 md:grid-cols-3">
      <div class="rounded-xl border border-gray-200 p-8">
        <h3 class="text-xl font-semibold">Resume-Aware Questions</h3>
        <p class="mt-3 text-gray-600">
          AI reads your resume and generates questions targeting your specific experience and skills.
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 p-8">
        <h3 class="text-xl font-semibold">Voice Recording</h3>
        <p class="mt-3 text-gray-600">
          Answer via voice like a real interview. AI transcribes and evaluates your spoken response.
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 p-8">
        <h3 class="text-xl font-semibold">Company-Specific Prep</h3>
        <p class="mt-3 text-gray-600">
          Prepare for Google, Amazon, Razorpay, and 15+ companies with pattern-matched questions.
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 p-8">
        <h3 class="text-xl font-semibold">Detailed Scoring</h3>
        <p class="mt-3 text-gray-600">
          Get scores on relevance, depth, clarity, and structure. Plus a model answer for every
          question.
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 p-8">
        <h3 class="text-xl font-semibold">Progress Tracking</h3>
        <p class="mt-3 text-gray-600">
          Track your improvement over time. See weak areas and focus your preparation.
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 p-8">
        <h3 class="text-xl font-semibold">Affordable</h3>
        <p class="mt-3 text-gray-600">
          Starting at ₹499/month. Cheaper than a single session with a human coach.
        </p>
      </div>
    </section>
  </main>
</Base>
