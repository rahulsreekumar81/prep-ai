{
  "name": "@prepai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/groq": "^1.1.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@neondatabase/serverless": "^0.10.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prepai/db": "workspace:*",
    "@prepai/shared": "workspace:*",
    "ai": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.0",
    "groq-sdk": "^0.9.0",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "dotenv-cli": "^11.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
